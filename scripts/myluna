#!/bin/bash

LUNA_ROOT="/opt/myLuna"

case "$1" in

create-client)
    $LUNA_ROOT/shared/scripts/create-client.sh "$2"
    ;;

delete-client)
    $LUNA_ROOT/shared/scripts/delete-client.sh "$2"
    ;;

list-clients)
    $LUNA_ROOT/shared/scripts/list-clients.sh
    ;;

health-check)
    $LUNA_ROOT/shared/scripts/health-check.sh
    ;;

secret-add)
    $LUNA_ROOT/shared/scripts/secret-add.sh "$2" "$3"
    ;;

secret-list)
    $LUNA_ROOT/shared/scripts/secret-list.sh "$2"
    ;;

secret-export)
    $LUNA_ROOT/shared/scripts/secret-export.sh "$2"
    ;;

backup)
    $LUNA_ROOT/shared/scripts/backup-client.sh "$2"
    ;;

restore)
    $LUNA_ROOT/shared/scripts/restore-client.sh "$2" "$3"
    ;;

memory-init)
    $LUNA_ROOT/shared/scripts/memory-init.sh "$2"
    ;;

memory-index)
    $LUNA_ROOT/shared/scripts/memory-index.sh "$2"
    ;;

memory-search)
    $LUNA_ROOT/shared/scripts/memory-search.sh "$2" "$3"
    ;;

graph-add)
    $LUNA_ROOT/shared/scripts/graph-add.sh "$2" "$3" "$4" "$5"
    ;;

graph-list)
    $LUNA_ROOT/shared/scripts/graph-list.sh "$2"
    ;;

graph-search)
    $LUNA_ROOT/shared/scripts/graph-search.sh "$2" "$3"
    ;;

graph-explore)
    $LUNA_ROOT/shared/scripts/graph-explore.sh "$2" "$3"
    ;;

vector-index)
    $LUNA_ROOT/shared/scripts/vector-index.sh "$2"
    ;;

semantic-search)
    $LUNA_ROOT/shared/scripts/semantic-search.sh "$2" "${@:3}"
    ;;

*)
    echo ""
    echo "myLuna Commands"
    echo ""

    echo "Client:"
    echo "  myluna create-client NAME"
    echo "  myluna delete-client NAME"
    echo "  myluna list-clients"
    echo ""

    echo "Vault:"
    echo "  myluna secret-add CLIENT KEY"
    echo "  myluna secret-list CLIENT"
    echo "  myluna secret-export CLIENT"
    echo ""

    echo "Backup:"
    echo "  myluna backup CLIENT"
    echo "  myluna restore CLIENT BACKUP_FILE"
    echo ""

    echo "System:"
    echo "  myluna health-check"
    echo ""

    echo "Memory:"
    echo "  myluna memory-init CLIENT"
    echo "  myluna memory-index CLIENT"
    echo "  myluna memory-search CLIENT QUERY"
    echo ""

    echo "Graph:"
    echo "  myluna graph-add CLIENT SOURCE TYPE TARGET"
    echo "  myluna graph-list CLIENT"
    echo "  myluna graph-search CLIENT ENTITY"
    echo "  myluna graph-explore CLIENT ENTITY"
    echo ""

    echo "Vector:"
    echo "  myluna vector-index CLIENT"
    echo "  myluna semantic-search CLIENT QUERY"
    echo ""

    ;;
esac